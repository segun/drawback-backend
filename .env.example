PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=drawback
DB_SYNCHRONIZE=true

# MongoDB backup storage (all REQUIRED for backup system to function)
MONGO_URI=mongodb://localhost:27017/drawback_backups
MONGO_DB_NAME=drawback_backups
MONGO_BACKUP_COLLECTION=drawback_backup_metadata
MONGO_BACKUP_BUCKET=drawback_backup_files

# Backup scheduling behavior
# Run periodic backups every 2 hours for better coverage (720 backups/month with 120 retention = 10 days)
BACKUP_PERIODIC_ENABLED=true
BACKUP_PERIODIC_CRON=0 */2 * * *
BACKUP_TIMEZONE=UTC
BACKUP_PERIODIC_RETENTION_COUNT=120

# Optional: Custom MySQL binary paths
# Use these if mysqldump or mysql are not in your PATH, or if you need specific versions
# Examples:
#   MYSQLDUMP_BIN=/usr/local/mysql/bin/mysqldump
#   MYSQL_BIN=/usr/local/mysql/bin/mysql
# Defaults: mysqldump and mysql (from PATH)
# MYSQLDUMP_BIN=mysqldump
# MYSQL_BIN=mysql

# Redis Configuration (REQUIRED)
# Redis is mandatory for production deployments. Used for:
# - WebAuthn challenge storage with TTL (security-critical)
# - Optional: WebSocket scaling across multiple instances
REDIS_URL=redis://localhost:6379

# Admin user credentials (required for yarn add:admin script)
# Set these values and run: yarn add:admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# JWT Authentication
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (required for email confirmation redirects)
FRONTEND_URL=http://localhost:3001

# Email Configuration (required for account activation, password reset, etc.)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@example.com

# WebAuthn / Passkey Configuration
# WEBAUTHN_RP_ID: The Relying Party ID (usually your domain, e.g., "localhost" or "example.com")
# Must match the domain where the frontend is hosted
# WEBAUTHN_RP_ID: Relying Party ID - usually your domain (no protocol)
# For production: use your actual domain (e.g., drawback.chat)
# For local dev with mobile: mobile apps don't accept 'localhost', use production domain or tunnel
WEBAUTHN_RP_ID=localhost

# WEBAUTHN_RP_NAME: Human-readable name shown during passkey registration
WEBAUTHN_RP_NAME=Drawback

# WEBAUTHN_ORIGIN: Comma-separated list of allowed origins for WebAuthn ceremonies
# Web origins: Must include the protocol (http:// or https://) and match frontend URLs exactly
# Android origins: android:apk-key-hash:<SHA256_HASH> (get from your app's signing certificate)
#   To convert: echo "SHA256_WITH_COLONS" | tr -d ':' | xxd -r -p | base64 | tr '+/' '-_' | tr -d '='
# iOS origins: ios:bundle-id:<BUNDLE_IDENTIFIER> (e.g., ios:bundle-id:com.example.app)
# Example: https://drawback.chat,android:apk-key-hash:ABC...,ios:bundle-id:com.drawback.app
WEBAUTHN_ORIGIN=http://localhost:3001,http://localhost:8082
