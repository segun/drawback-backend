PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=drawback
DB_SYNCHRONIZE=true

# MongoDB backup storage (all REQUIRED for backup system to function)
MONGO_URI=mongodb://localhost:27017/drawback_backups
MONGO_DB_NAME=drawback_backups
MONGO_BACKUP_COLLECTION=drawback_backup_metadata
MONGO_BACKUP_BUCKET=drawback_backup_files

# Backup scheduling behavior
# Run periodic backups every 2 hours for better coverage (720 backups/month with 120 retention = 10 days)
BACKUP_PERIODIC_ENABLED=true
BACKUP_PERIODIC_CRON=0 */2 * * *
BACKUP_TIMEZONE=UTC
BACKUP_PERIODIC_RETENTION_COUNT=120

# Optional: Custom MySQL binary paths
# Use these if mysqldump or mysql are not in your PATH, or if you need specific versions
# Examples:
#   MYSQLDUMP_BIN=/usr/local/mysql/bin/mysqldump
#   MYSQL_BIN=/usr/local/mysql/bin/mysql
# Defaults: mysqldump and mysql (from PATH)
# MYSQLDUMP_BIN=mysqldump
# MYSQL_BIN=mysql

# Optional: required only when scaling websockets across multiple app instances
# REDIS_URL=redis://localhost:6379
# NOTE: Redis caching has been removed from the application. If you need to
# re-enable it in the future for specific hot endpoints, uncomment CacheModule
# in app.module.ts and update the relevant service files.

# Admin user credentials (required for yarn add:admin script)
# Set these values and run: yarn add:admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
